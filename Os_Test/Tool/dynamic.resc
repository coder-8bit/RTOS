:name: Dynamic eVCU Test Network
emulation CreateCANHub "canHub"

mach create "eVCU"
machine LoadPlatformDescription @debug/stm32f103_full.repl
connector Connect sysbus.can1 canHub
sysbus.usart1 CreateFileBackend @/Users/phamvanvu/Projects/AUTOSAR/OSEK-RTOS/Os_Test/Tool/logs/evcu_uart.log true
sysbus LoadELF @/Users/phamvanvu/Projects/AUTOSAR/OSEK-RTOS/Os_Test/build/os_test/os_test.elf
machine StartGdbServer 3333

mach create "Diag_ECU"
machine LoadPlatformDescription @debug/stm32f103_full.repl
connector Connect sysbus.can1 canHub
sysbus.usart1 CreateFileBackend @/Users/phamvanvu/Projects/AUTOSAR/OSEK-RTOS/Os_Test/Tool/logs/diag_uart.log true
sysbus LoadELF @/Users/phamvanvu/HALAAcademy/01_Courses/AUTOSAR_Classic/COM/build/example/evcu_diag_ecu.elf
machine StartGdbServer 3334

mach create "Com_ECU"
machine LoadPlatformDescription @debug/stm32f103_full.repl
connector Connect sysbus.can1 canHub
sysbus.usart1 CreateFileBackend @/Users/phamvanvu/Projects/AUTOSAR/OSEK-RTOS/Os_Test/Tool/logs/com_uart.log true
sysbus LoadELF @/Users/phamvanvu/HALAAcademy/01_Courses/AUTOSAR_Classic/COM/build/example/evcu_com_ecu.elf
machine StartGdbServer 3335

logLevel 3 sysbus
start
