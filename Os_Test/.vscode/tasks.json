{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Make build (Mixed + ScheduleTable)",
      "type": "shell",
      "command": "make",
      "args": ["clean", "all"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Renode cleanup",
      "type": "shell",
      "command": "pkill -f 'Renode|renode' 2>/dev/null; lsof -ti:3333 | xargs kill -9 2>/dev/null; sleep 0.5; echo 'Port 3333 da duoc don sach'",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Renode start (manual GDB)",
      "type": "shell",
      "command": "/Applications/Renode.app/Contents/MacOS/renode",
      "args": [
        "--console",
        "--disable-gui",
        "renode.resc"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": ".*"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*Renode, version.*",
          "endsPattern": ".*Renode ready for GDB connection.*"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false
      }
    },
    {
      "label": "Renode prepare Mixed + ScheduleTable",
      "dependsOn": [
        "Renode cleanup",
        "Make build (Mixed + ScheduleTable)",
        "Renode start (manual GDB)"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    }
  ]
}
